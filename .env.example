# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Auth PIN
# PIN yang digunakan untuk login ke aplikasi
AUTH_PIN=123456
# Secret key untuk HMAC token (gunakan string acak yang panjang)
AUTH_SECRET=your_random_secret_string

# Panjang PIN yang ditampilkan di UI (default: 6)
NEXT_PUBLIC_PIN_LENGTH=6
